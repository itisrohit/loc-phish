# ==========================================
# Authentication
# ==========================================
# Password required to log into the dashboard.
AUTH_PASSWORD=changeme

# ==========================================
# Firebase / Firestore (Optional)
# ==========================================
# Leave empty for mock mode (localStorage + .mock/db.json).
# Fill in to persist visitor logs to Cloud Firestore.
#
# Get these from Firebase Console → Project Settings → General → Your apps
#
# Only 2 fields are needed since we only use Firestore (no Auth/Storage/etc).

# Firebase API key
NEXT_PUBLIC_FIREBASE_API_KEY=

# Firebase project ID
NEXT_PUBLIC_FIREBASE_PROJECT_ID=